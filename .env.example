# Server Configuration
PORT=3001
NODE_ENV=production
API_BASE_URL=https://your-service.onrender.com
FRONTEND_URL=https://your-service.onrender.com
CORS_ORIGIN=*

# Database Configuration
# Use your Supabase or external PostgreSQL connection string
DATABASE_URL="postgresql://username:password@host:5432/baileys_api?schema=public"

# JWT Configuration
JWT_SECRET=generate-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# API Security
API_KEY_SECRET=generate-a-random-string-at-least-32-chars
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp Configuration
WA_SESSION_TIMEOUT=300000
WA_MAX_RETRY_COUNT=3
WA_KEEP_ALIVE_INTERVAL=30000
WA_CONNECTION_TIMEOUT=20000

# File Upload Configuration
# Use a plain number (MB) — do NOT include 'mb' suffix here
MAX_FILE_SIZE=50
UPLOAD_PATH=./uploads
TEMP_PATH=./temp

# Webhook Configuration
WEBHOOK_SECRET=generate-a-random-string-at-least-32-chars
WEBHOOK_TIMEOUT=10000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Redis Configuration (Optional - for session clustering)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Configuration (Optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Monitoring Configuration (Optional)
SENTRY_DSN=
PROMETHEUS_PORT=9090
